# LiveKit local (dev mode)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Agent dispatch name (token payload will target this)
AGENT_NAME=db-agent

# OpenAI (cloud LLM)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_COMPLETION_TOKENS=96
USE_OPENAI_STT=true
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_DETECT_LANGUAGE=false
OPENAI_STT_LANGUAGE=en
OPENAI_STT_PROMPT=User speaks English; transcribe clearly and keep emails/names accurate.
USE_OPENAI_TTS=true
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=shimmer
OPENAI_TTS_SPEED=1.05
OPENAI_TTS_INSTRUCTIONS=Energetic warm helpful female assistant voice with natural pacing and smiley tone.
OPENAI_WARMUP=false
OPENAI_WARMUP_TIMEOUT_MS=15000

# Prompt controls
AGENT_SYSTEM_PROMPT_FILE=./prompt.md
# AGENT_SYSTEM_PROMPT=Optional inline prompt override
AGENT_GREETING=Hello, I am ready. How can I help you today?

# Agent behavior
ENABLE_TOOLS=true
AGENT_MAX_SPOKEN_WORDS=24
VOICE_ALLOW_INTERRUPTIONS=true
VOICE_MIN_INTERRUPTION_DURATION_MS=500
VOICE_MIN_INTERRUPTION_WORDS=2
VOICE_MIN_ENDPOINTING_DELAY_MS=500
VOICE_MAX_ENDPOINTING_DELAY_MS=3000
VOICE_PREEMPTIVE_GENERATION=false

# Local STT fallback tuning (used when USE_OPENAI_STT=false)
STT_SILENCE_FLUSH_MS=520
STT_MAX_SEGMENT_MS=10000
STT_MIN_SPEECH_MS=180
STT_SPEECH_RMS_THRESHOLD=0.02

# Local STT/TTS services (only used when USE_OPENAI_STT=false and/or USE_OPENAI_TTS=false)
STT_SERVICE_URL=http://127.0.0.1:4020
TTS_SERVICE_URL=http://127.0.0.1:4030
WHISPER_MODEL=base
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0

# Backend / DB API
DB_API_BASE_URL=http://127.0.0.1:4010
DB_API_AUTH_TOKEN=
# If using tools-api-starter service (docker compose --profile tools), switch to:
# DB_API_BASE_URL=http://127.0.0.1:4011

# tools-api-starter (optional production-oriented backend starter)
TOOLS_API_STARTER_PORT=4011
TOOLS_API_CORS_ORIGIN=*
TOOLS_API_REQUIRE_AUTH=false
TOOLS_API_AUTH_TOKEN=change-me-tools-token
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/va_voice
REDIS_URL=redis://127.0.0.1:6379
TOOLS_WEBHOOK_URL=
TOOLS_WEBHOOK_SECRET=
TOOLS_WEBHOOK_TIMEOUT_MS=4000
TOOLS_WEBHOOK_MAX_ATTEMPTS=5
TOOLS_WEBHOOK_BACKOFF_MS=1000

# Token server
TOKEN_SERVER_PORT=3000
TOKEN_TTL=24h
TOKEN_SERVER_CORS_ORIGIN=*
TOKEN_SERVER_REQUIRE_API_KEY=false
TOKEN_SERVER_API_KEYS=
TOKEN_SERVER_RATE_LIMIT_WINDOW_MS=60000
TOKEN_SERVER_RATE_LIMIT_MAX=120
